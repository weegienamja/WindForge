# WindForge environment configuration. Copy to .env.local and fill in.

# Copernicus Climate Data Store API key. Optional. When set, WindForge fetches
# ERA5 and (in Europe) CERRA reanalysis and bias-corrects NASA POWER against
# the higher-resolution reference. Without this key the analysis still works
# but the bias correction step is skipped and confidence is marked low.
# Get a key at https://cds.climate.copernicus.eu/how-to-api
CDS_API_KEY=

# Logger verbosity. One of: error, warn, info, debug. Defaults to info.
LOG_LEVEL=info
